# Template only — never commit a real .env file.
# In production, all of these come from GCP Secret Manager at runtime.
# Use this file for local development only.

# Anthropic API key — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — from @BotFather (/token)
TELEGRAM_BOT_TOKEN=1234567890:ABC...

# Telegram chat targets — numeric IDs
TELEGRAM_OWNER_CHAT_ID=937808375          # Prabhu's personal chat
TELEGRAM_GROUP_CHAT_ID=                   # filled in once group is active (negative integer)

# Notion API token (internal integration token) — https://www.notion.so/profile/integrations
NOTION_API_TOKEN=secret_...

# Notion data source IDs (collection://...)
NOTION_COMMITMENTS_DS=d42a2708-214e-4f31-8933-422dee8d0a09
NOTION_TASKS_DS=184cc773-5a57-4fe2-848d-499a85adfbeb
NOTION_REPORTS_DUE_DS=67fe49c0-9bae-41c7-a1b0-594a42a0c450
NOTION_MEETINGS_DS=60e7301c-2a44-4c6e-8b31-c46a1b930770
NOTION_BRIEFINGS_DS=4f32be90-b07c-41bd-add5-58a55d6e1b1c
NOTION_CONVERSATIONS_DS=348c3ae8-9729-41e5-945f-2da9c241ac19

# Google Drive
DRIVE_BRAIN_INBOX_FOLDER_ID=1-Qh-aklaTB9CNr7QTQgdum_QKdFNOLkL

# OpenAI Whisper (for voice transcription)
OPENAI_API_KEY=sk-...

# Gmail OAuth (refresh token, obtained once via OAuth playground for prabhugandhikumar@gmail.com)
GMAIL_REFRESH_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Microsoft Graph (Outlook) — app registration in Azure
MS_TENANT_ID=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=

# Dashboard auth — bcrypt-hashed passwords. YAML map of username → hash.
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'mypassword', bcrypt.gensalt()).decode())"
DASHBOARD_USERS_YAML=

# Dashboard session secret (any 32+ random chars)
SESSION_SECRET=change-me-to-a-random-string

# Runtime
ENV=development
LOG_LEVEL=INFO
